<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.dam_a15044coolweatherapp.WeatherViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:windowBackground"
        android:padding="16dp"
        tools:context=".MainActivity">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="?attr/colorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/weatherImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="20dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_sun"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/coordsPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/weatherImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/latitude_label"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/latitudeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg"
                android:hint="@string/latitude_hint"
                android:inputType="numberDecimal|numberSigned"
                android:padding="12dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:text="@={viewModel.latitude}"
                android:textColor="?android:textColor"
                android:textColorHint="?android:textColorHint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/longitude_label"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/longitudeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg"
                android:hint="@string/longitude_hint"
                android:inputType="numberDecimal|numberSigned"
                android:padding="12dp"
                android:text="@={viewModel.longitude}"
                android:textColor="?android:textColor"
                android:textColorHint="?android:textColorHint" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dataPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/coordsPanel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/pressureLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pressure_label"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pressureValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{viewModel.pressure}"
                tools:text="1013 hPa"
                android:textColor="?android:textColor"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/windDirectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/wind_direction_label"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/windDirectionValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{viewModel.windDirection}"
                tools:text="180°"
                android:textColor="?android:textColor" />

            <TextView
                android:id="@+id/windSpeedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/wind_speed_label"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/windSpeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{viewModel.windSpeed}"
                tools:text="10 km/h"
                android:textColor="?android:textColor" />

            <TextView
                android:id="@+id/temperatureLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/temperature_label"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/temperatureValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{viewModel.temperature}"
                tools:text="25 °C"
                android:textColor="?android:textColor" />

            <TextView
                android:id="@+id/timeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/time_label"
                android:textColor="?attr/colorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{viewModel.time}"
                tools:text="2023-10-27T12:00"
                android:textColor="?android:textColor" />
        </LinearLayout>

        <Button
            android:id="@+id/updateButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_bg"
            android:text="@string/update_button"
            android:textAllCaps="true"
            android:textColor="?attr/weatherButtonText"
            android:textStyle="bold"
            android:onClick="@{() -> viewModel.onUpdateClick()}"
            app:layout_constraintTop_toBottomOf="@id/dataPanel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>